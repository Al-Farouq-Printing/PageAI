rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // بيانات المستخدم: يقدر يقرأ ويكتب بيانات نفسه بس
    // ومينفعش يغيّر plan أو subscriptionExpiry بنفسه (دول بيتغيروا يدويًا من Firebase Console بس)
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['dailyCount', 'dailyDate']);
    }

    // المواقع المنشورة: أي حد يقدر يقرأها (عشان الروابط العامة تشتغل)، وبس صاحبها يقدر ينشئها
    match /sites/{siteId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.uid;
      allow update, delete: if false;
    }
  }
}
